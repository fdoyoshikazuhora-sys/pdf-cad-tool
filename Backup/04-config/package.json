{
  "name": "app-output-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Safe generator for wrapping a standalone browser app as a React App_minimal.js output.",
  "scripts": {
    "generate": "node scripts/generate-app-minimal.mjs",
    "preview": "node scripts/generate-app-minimal.mjs --preview",
    "apply": "node scripts/generate-app-minimal.mjs --apply",
    "check": "node scripts/generate-app-minimal.mjs --check",
    "check:no-sample": "node scripts/generate-app-minimal.mjs --check --no-embed-assets",
    "report": "node scripts/report.mjs",
    "contract": "node scripts/check-bridge-contract.mjs",
    "backups": "node scripts/list-backups.mjs",
    "restore:sandbox": "node scripts/restore-sandbox-backup.mjs",
    "doctor": "node scripts/doctor.mjs",
    "package:promotion": "node scripts/package-promotion.mjs",
    "package:light": "node scripts/package-light.mjs",
    "package:host-review": "node scripts/package-host-review.mjs",
    "package:public": "node scripts/package-public-release.mjs",
    "public:check": "node scripts/check-public-release.mjs",
    "promotion:check": "node scripts/check-promotion.mjs",
    "vendor:status": "node scripts/vendor-status.mjs",
    "vendor:download": "node scripts/download-vendors.mjs",
    "vendor:check-local": "node scripts/apply-local-vendor.mjs",
    "vendor:apply-local": "node scripts/apply-local-vendor.mjs --apply",
    "safety": "node scripts/safety-check.mjs",
    "verify": "node scripts/verify-workflow.mjs",
    "release:check": "node scripts/release-check.mjs",
    "refresh:sandbox": "node scripts/refresh-sandbox-copy.mjs",
    "serve:preview": "node scripts/serve-static.mjs out 5212 \"/preview.html\"",
    "serve:io-harness": "node scripts/serve-static.mjs out 5212 \"/bridge-io-harness.html\"",
    "serve:api-harness": "node scripts/serve-static.mjs out 5212 \"/bridge-api-harness.html\"",
    "serve:light": "node scripts/serve-static.mjs dist-light-package 5213 \"/preview-host.html\"",
    "serve:light-api": "node scripts/serve-static.mjs dist-light-package 5213 \"/light-api-harness.html\"",
    "serve:public": "node scripts/serve-static.mjs public-release 5214 \"/index.html\"",
    "open:preview": "npm run verify && npm run serve:preview",
    "open:api-harness": "npm run verify && npm run serve:api-harness"
  }
}
